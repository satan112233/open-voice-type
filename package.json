{
  "name": "open-voice-type",
  "private": true,
  "version": "0.1.8",
  "description": "An open-source, local-first AI voice dictation app for Windows and macOS.",
  "author": "OpenVoiceType Contributors",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev -- --remote-debugging-port=9223",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "build": {
    "appId": "com.openvoicetype.app",
    "productName": "语音输入助手",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/sherpa-onnx",
        "to": "sherpa-onnx",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      }
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "koffi": "^3.0.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tar": "^7.5.16",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.3"
  }
}
